<!DOCTYPE html>
<html lang="es" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="x-apple-disable-message-reformatting" />
  <title>Configura tu contraseña</title>
  <style>
    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .content-padding { padding: 24px 20px !important; }
      .btn-cta { padding: 14px 28px !important; font-size: 15px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#f0f2f5; font-family:'Helvetica Neue',Arial,sans-serif; -webkit-font-smoothing:antialiased;">

  <%# Outer wrapper %>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0f2f5;">
    <tr>
      <td align="center" style="padding: 40px 16px;">

        <%# Card container %>
        <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0"
               style="max-width:600px; width:100%; background-color:#ffffff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.10);">

          <%# ── Header ── %>
          <tr>
            <td style="background: linear-gradient(135deg, #1e2a4a 0%, #2d4080 100%); padding: 40px 48px 36px; text-align:center;">

              <%# Logo / nombre de empresa %>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td align="center">
                    <%# Ícono circular con inicial %>
                    <div style="display:inline-block; width:56px; height:56px; border-radius:50%;
                                background:rgba(255,255,255,0.15); border:2px solid rgba(255,255,255,0.3);
                                line-height:56px; text-align:center; font-size:26px; font-weight:800;
                                color:#ffffff; margin-bottom:14px;">
                      <%= (company_name || "G")[0].upcase %>
                    </div>
                  </td>
                </tr>
                <tr>
                  <td align="center">
                    <p style="margin:0; font-size:22px; font-weight:800; color:#ffffff; letter-spacing:0.5px;">
                      <%= company_name || "Grupo Bothi" %>
                    </p>
                    <p style="margin:6px 0 0; font-size:12px; color:rgba(255,255,255,0.55); letter-spacing:1px; text-transform:uppercase;">
                      Sistema de gestión empresarial
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <%# ── Banda de acento ── %>
          <tr>
            <td style="height:4px; background: linear-gradient(90deg, #4f8ef7 0%, #7c5cfc 100%);"></td>
          </tr>

          <%# ── Cuerpo ── %>
          <tr>
            <td class="content-padding" style="padding: 44px 48px 36px;">

              <%# Saludo %>
              <p style="margin:0 0 8px; font-size:26px; font-weight:700; color:#1a202c;">
                ¡Bienvenido, <%= user.first_name %>!
              </p>
              <p style="margin:0 0 24px; font-size:15px; color:#718096;">
                Tu cuenta ha sido creada exitosamente.
              </p>

              <%# Separador delgado %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="height:1px; background-color:#e8ecf0; margin-bottom:24px;"></td></tr>
              </table>
              <div style="height:24px;"></div>

              <p style="margin:0 0 16px; font-size:15px; color:#4a5568; line-height:1.7;">
                Se ha creado una cuenta para ti en <strong style="color:#1a202c;"><%= company_name || "Grupo Bothi" %></strong>.
                Para comenzar a usar el sistema, necesitas configurar tu contraseña de acceso.
              </p>

              <%# Caja de correo %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background-color:#f7faff; border:1px solid #d0e0ff; border-radius:10px; margin: 20px 0;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0; font-size:12px; color:#7a8da8; text-transform:uppercase; letter-spacing:0.8px; font-weight:600;">
                      Tu correo de acceso
                    </p>
                    <p style="margin:6px 0 0; font-size:16px; font-weight:700; color:#2d4080;">
                      <%= user.email %>
                    </p>
                  </td>
                </tr>
              </table>

              <p style="margin:0 0 28px; font-size:15px; color:#4a5568; line-height:1.7;">
                Haz clic en el botón de abajo para configurar tu contraseña. El enlace es personal e intransferible.
              </p>

              <%# Botón CTA %>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td align="center" style="padding: 8px 0 32px;">
                    <a href="<%= set_password_url %>"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="btn-cta"
                       style="display:inline-block; padding:16px 40px; border-radius:50px;
                              background: linear-gradient(135deg, #4f8ef7 0%, #7c5cfc 100%);
                              color:#ffffff; font-size:16px; font-weight:700; text-decoration:none;
                              letter-spacing:0.3px; box-shadow:0 6px 20px rgba(79,142,247,0.4);">
                      Configurar mi contraseña &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <%# Enlace de respaldo %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background-color:#f7f8fa; border:1px solid #e2e8f0; border-radius:8px; margin-bottom:24px;">
                <tr>
                  <td style="padding:14px 16px;">
                    <p style="margin:0 0 6px; font-size:12px; color:#a0aec0; font-weight:600; text-transform:uppercase; letter-spacing:0.6px;">
                      Si el botón no funciona, copia este enlace en tu navegador:
                    </p>
                    <p style="margin:0; font-size:12px; color:#4a5568; word-break:break-all; font-family:monospace;">
                      <%= set_password_url %>
                    </p>
                  </td>
                </tr>
              </table>

              <%# Nota de expiración %>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                     style="background-color:#fffbeb; border:1px solid #f6e05e; border-radius:8px; margin-bottom:8px;">
                <tr>
                  <td style="padding:12px 16px;">
                    <p style="margin:0; font-size:13px; color:#92600a; line-height:1.5;">
                      &#9203; Este enlace expira en <strong>72 horas</strong>. Si no lo usas en ese tiempo,
                      solicita uno nuevo a tu administrador.
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <%# ── Divider ── %>
          <tr>
            <td style="padding: 0 48px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="height:1px; background-color:#e8ecf0;"></td></tr>
              </table>
            </td>
          </tr>

          <%# ── Aviso de seguridad ── %>
          <tr>
            <td style="padding: 20px 48px;">
              <p style="margin:0; font-size:12px; color:#a0aec0; line-height:1.6; text-align:center;">
                Si no esperabas este correo, puedes ignorarlo con toda tranquilidad.
                Nadie podrá acceder a tu cuenta sin configurar una contraseña.
              </p>
            </td>
          </tr>

          <%# ── Footer ── %>
          <tr>
            <td style="background-color:#f7f8fa; border-top:1px solid #e8ecf0; padding:24px 48px; text-align:center; border-radius:0 0 16px 16px;">
              <p style="margin:0 0 4px; font-size:13px; color:#a0aec0; font-weight:600;">
                <%= company_name || "Grupo Bothi" %>
              </p>
              <p style="margin:0; font-size:12px; color:#c0ccda;">
                &copy; <%= Time.now.year %> Todos los derechos reservados.
              </p>
            </td>
          </tr>

        </table>
        <%# / Card container %>

      </td>
    </tr>
  </table>

</body>
</html>
